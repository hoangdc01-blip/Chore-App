# ── Data Sync ──
# Set to true for cross-device sync via Firebase
# Set to false for local-only mode (localStorage)
VITE_USE_FIREBASE=true

# ── Firebase Config ──
# Get these from Firebase Console > Project Settings > Your apps
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# ── AI Buddy (Ollama) ──
# URL where Ollama is running
VITE_OLLAMA_URL=http://localhost:11434
# Text model — qwen2.5:7b for CPU, qwen2.5:14b for Apple Silicon/GPU
VITE_OLLAMA_TEXT_MODEL=qwen2.5:7b
# Vision model for image analysis
VITE_OLLAMA_VISION_MODEL=llava:7b
